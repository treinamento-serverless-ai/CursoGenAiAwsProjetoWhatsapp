# Copy this file to terraform.tfvars and fill with your values
# DO NOT commit terraform.tfvars to version control

aws_region = "us-east-1"

# Custom domain + mTLS (opcional)
# Pré-requisitos: domínio no Route 53 + certificado Meta CA (.pem) em certs/
# Download: https://developers.facebook.com/docs/graph-api/webhooks/getting-started/#downloadable-root-certificate
# Para desabilitar, comente a linha abaixo.
# custom_domain_name = "your-domain.com"

cognito_admin_users = [
  { name = "Admin User", email = "admin@example.com" }
]

cognito_regular_users = [
  { name = "Regular User", email = "user@example.com" }
]
