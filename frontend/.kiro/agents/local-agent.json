{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "local-agent",
  "description": "Local agent for workspace MCPs",
  "prompt": null,
  "mcpServers": {
    "angular-cli": {
      "type": "stdio",
      "command": "ng",
      "args": ["mcp"],
      "env": {
        "PWD": "."
      },
      "timeout": 120000,
      "disabled": false
    }
  },
  "tools": ["*"],
  "toolAliases": {},
  "allowedTools": ["*"],
  "resources": [],
  "hooks": {},
  "toolsSettings": {
    "use_aws": {
      "alwaysAllow": [
        {
          "preset": "readOnly"
        }
      ]
    },
    "execute_bash": {
      "alwaysAllow": [
        {
          "preset": "readOnly"
        }
      ]
    }
  },
  "useLegacyMcpJson": false,
  "model": null
}
